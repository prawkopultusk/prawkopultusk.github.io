            </div>
            <div class="offer-card">
                <i class="fas fa-motorcycle"></i>
                <h3>Prawo jazdy A / A2</h3>
                <p>Profesjonalne szkolenie na motocykl, bezpieczeństwo i technika.</p>
                <div class="price">od 1990 zł</div>
            </div>
            <div class="offer-card">
                <i class="fas fa-sync-alt"></i>
                <h3>Jazdy doszkalające</h3>
                <p>Indywidualne godziny, egzamin wewnętrzny, elastyczne terminy.</p>
                <div class="price">120 zł / h</div>
            </div>
            <div class="offer-card">
                <i class="fas fa-graduation-cap"></i>
                <h3>Kursy intensywne</h3>
                <p>Zdać w miesiąc! Zajęcia codziennie, szybki kurs z egzaminem.</p>
                <div class="price">2990 zł</div>
            </div>
        </div>
    </section>

    <!-- KONTAKT I FORMUŁARZ -->
    <section id="contact" class="section">
        <h2 class="section-title">Kontakt i zapisy</h2>
        <p class="section-sub">Skontaktuj się z nami – odpowiemy na wszystkie pytania i umówimy jazdę próbną.</p>
        <div class="contact-wrapper">
            <div class="contact-info">
                <div class="info-row"><i class="fas fa-map-marker-alt"></i> aleja Tysiąclecia 12 (wjazd od Harcerskiej), 06-100 Pułtusk</div>
                <div class="info-row"><i class="fas fa-phone-alt"></i> 512 103 512</div>
                <div class="info-row"><i class="fas fa-envelope"></i> biuro@prawkopultusk.pl</div>
                <div class="info-row"><i class="far fa-clock"></i> Pon-Pt: 8:00–20:00, Sob: 9:00–14:00</div>
                <div class="social-icons">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-youtube"></i></a>
                </div>
                <div style="margin-top: 1.5rem;">
                    <i class="fas fa-map-pin"></i> <strong>Mapa dojazdu:</strong> <a href="#" style="color:#1363df;">Google Maps – zobacz trasę</a>
                </div>
            </div>
            <div class="contact-form">
                <form id="contactForm">
                    <div class="form-group">
                        <input type="text" id="name" placeholder="Imię i nazwisko" required>
                    </div>
                    <div class="form-group">
                        <input type="tel" id="phone" placeholder="Numer telefonu" required>
                    </div>
                    <div class="form-group">
                        <input type="email" id="email" placeholder="Adres e-mail">
                    </div>
                    <div class="form-group">
                        <textarea rows="4" id="message" placeholder="Twoja wiadomość / wybór kursu" required></textarea>
                    </div>
                    <button type="submit" class="btn">Wyślij wiadomość <i class="fas fa-paper-plane"></i></button>
                    <p id="formFeedback" style="margin-top: 1rem; font-size: 0.8rem; color: #1363df;"></p>
                </form>
            </div>
        </div>
    </section>
</main>

<footer>
    <p>&copy; 2025 Prawko Pułtusk – Nauka Jazdy Mariusz Kowalewski | Nowoczesna szkoła jazdy w Pułtusku | Godziny otwarcia: 08:00–20:00</p>
    <p style="margin-top: 0.6rem; font-size: 0.8rem;"><i class="fas fa-car-side"></i> Ponad 5000 zdanych egzaminów | Dołącz do nas już dziś!</p>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/js/lightbox-plus-jquery.min.js"></script>
<script>
    // Mobile menu toggle
    const mobileBtn = document.getElementById('mobile-menu');
    const navLinks = document.getElementById('nav-links');
    mobileBtn.addEventListener('click', () => {
        navLinks.classList.toggle('show');
    });

    // smooth scroll + active link highlight
    const sections = document.querySelectorAll('section');
    const navItems = document.querySelectorAll('.nav-item');

    window.addEventListener('scroll', () => {
        let current = '';
        sections.forEach(section => {
            const sectionTop = section.offsetTop - 100;
            if (pageYOffset >= sectionTop) {
                current = section.getAttribute('id');
            }
        });
        navItems.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === `#${current}`) {
                link.classList.add('active');
            }
        });
    });

    // form submission simulation (without actual page reload)
    const contactForm = document.getElementById('contactForm');
    const feedback = document.getElementById('formFeedback');
    contactForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const name = document.getElementById('name').value.trim();
        const phone = document.getElementById('phone').value.trim();
        if (!name || !phone) {
            feedback.innerHTML = '⚠️ Proszę uzupełnić imię i numer telefonu.';
            feedback.style.color = '#c62828';
            return;
        }
        feedback.innerHTML = '✅ Dziękujemy! Skontaktujemy się najszybciej jak to możliwe.';
        feedback.style.color = '#1363df';
        contactForm.reset();
        setTimeout(() => { feedback.innerHTML = ''; }, 4000);
    });

    // dodatkowe: mała interakcja dla przycisku "Zobacz zdjęcia" na wypadek odesłania
    console.log("Prawko Pułtusk - strona gotowa");
</script>
</body>
</html>
